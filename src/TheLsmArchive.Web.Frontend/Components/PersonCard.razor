@inject NavigationManager NavigationManager

<MudCard Class="h-100 card-hover hover-secondary entity-card clickable-card flex-grow-1">
    <MudCardContent @onclick='() => NavigationManager.NavigateTo($"/Person/{Person.Id}")'>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Secondary" Size="Size.Small"/>
            <MudText Typo="Typo.body1" Class="fw-bold">@Person.Name</MudText>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {

    [Parameter, EditorRequired]
    public Person Person { get; set; } = default!;

}
