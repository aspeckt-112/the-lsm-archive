@inject NavigationManager NavigationManager

<MudCard Class="h-100 card-hover hover-tertiary entity-card clickable-card flex-grow-1">
    <MudCardContent @onclick='() => NavigationManager.NavigateTo($"/Topic/{Topic.Id}")'>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Tag" Color="Color.Tertiary" Size="Size.Small"/>
            <MudText Typo="Typo.body1" Class="fw-bold">@Topic.Name</MudText>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {

    [Parameter, EditorRequired]
    public Topic Topic { get; set; } = default!;

}
