@page "/Topic/{Id:int}"

@using TheLsmArchive.ApiClient.Services.Abstractions
@using TheLsmArchive.Models.Request
@using TheLsmArchive.Web.Frontend.Pages.Abstractions

@inherits BasePage

@implements IDisposable

@inject ILogger<TopicPage> Logger
@inject ILsmArchiveClientService ClientService
@inject NavigationManager NavigationManager
@inject IBreadcrumbService BreadcrumbService

<MudGrid Spacing="5">
    @if (_topic != null && _topicDetails != null)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-6 page-header header-tertiary" Elevation="4">
                <MudGrid Spacing="2">
                    <MudItem xs="12" lg="7">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Color="Color.Tertiary" Size="Size.Large"/>
                            <MudText Typo="Typo.h4" Class="fw-bold">@_topic.Name</MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" lg="5">
                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="flex-wrap">
                            <MudChip T="string"
                                     Icon="@Icons.Material.Filled.CalendarToday"
                                     Color="Color.Default"
                                     Variant="Variant.Text"
                                     Class="pa-4">
                                First Discussed: <strong>@_topicDetails.FirstDiscussed.ToShortDateString()</strong>
                            </MudChip>
                            <MudChip T="string"
                                     Icon="@Icons.Material.Filled.Update"
                                     Color="Color.Default"
                                     Variant="Variant.Text"
                                     Class="pa-4">
                                Last Discussed: <strong>@_topicDetails.LastDiscussed.ToShortDateString()</strong>
                            </MudChip>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <SectionHeader Icon="@Icons.Material.Filled.Headphones" Color="Color.Primary" Title="Episodes"/>
            <MudTextField
                T="string"
                Variant="Variant.Outlined"
                Placeholder="Search episodes..."
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Search"
                AdornmentColor="Color.Primary"
                Value="_episodeSearchTerm"
                ValueChanged="OnEpisodeSearchTermChanged"
                Immediate="true"
                FullWidth="true"
                Clearable="true"
                Margin="Margin.Dense"
                Class="mb-4" />
            @if (_isLoadingEpisodes)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
            }
            @if (_episodesResponse is { Items.Count: > 0 })
            {
                <MudGrid Spacing="3">
                    @foreach (var episode in _episodesResponse.Items)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3" Class="d-flex">
                            <EpisodeCard Episode="episode"/>
                        </MudItem>
                    }
                </MudGrid>
                @if (_episodesResponse.TotalPages > 1)
                {
                    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                        <MudPagination Count="@_episodesResponse.TotalPages"
                                       Selected="@_currentEpisodePage"
                                       SelectedChanged="OnEpisodePageChanged"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       BoundaryCount="1"
                                       MiddleCount="3"
                                       ShowFirstButton="true"
                                       ShowLastButton="true" />
                    </MudStack>
                }
            }
            else if (_episodesResponse is not null)
            {
                <MudText Typo="Typo.body2" Class="mt-2" Style="opacity: 0.6;">No episodes found.</MudText>
            }
            else
            {
                <MudContainer Class="d-flex justify-center py-4">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                </MudContainer>
            }
        </MudItem>

        @if (_persons?.Count > 0)
        {
            <MudItem xs="12">
                <SectionHeader Icon="@Icons.Material.Filled.People" Color="Color.Secondary" Title="People"/>
                <MudGrid Spacing="3">
                    @foreach (var person in _persons)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3" Class="d-flex">
                            <PersonCard Person="person"/>
                        </MudItem>
                    }
                </MudGrid>
            </MudItem>
        }
    }
    else
    {
        <MudItem xs="12">
            <MudPaper Class="pa-6 rounded-lg" Elevation="4">
                <MudGrid Spacing="2">
                    <MudItem xs="12" lg="7">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="48px" Height="48px"/>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Height="48px"/>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" lg="5">
                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="flex-wrap">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="180px" Height="36px" Class="rounded-pill"/>
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="180px" Height="36px" Class="rounded-pill"/>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    private const int PageSize = 50;
    private const int SearchDebounceMs = 350;

    [Parameter]
    public int Id { get; set; }

    private Topic? _topic;

    private TopicDetails? _topicDetails;

    private PagedResponse<Episode>? _episodesResponse;

    private List<Person>? _persons;

    private int _currentEpisodePage = 1;

    private string _episodeSearchTerm = string.Empty;

    private bool _isLoadingEpisodes;

    private CancellationTokenSource? _episodeSearchDebounceCts;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Push("Loading...", NavigationManager.Uri, Icons.Material.Filled.Tag);

        using CancellationTokenSource cts = new();

        var getTopicTask = GetTopic(cts.Token);
        var getTopicDetailsTask = GetTopicDetails(cts.Token);
        var getEpisodesTask = GetEpisodes(_currentEpisodePage, cts.Token);
        var getPersonsTask = GetPersons(cts.Token);

        await Task.WhenAll(getTopicTask, getTopicDetailsTask, getEpisodesTask, getPersonsTask);
    }

    private async Task OnEpisodeSearchTermChanged(string value)
    {
        _episodeSearchTerm = value;
        _currentEpisodePage = 1;
        _isLoadingEpisodes = true;

        _episodeSearchDebounceCts?.Cancel();
        _episodeSearchDebounceCts = new CancellationTokenSource();
        var token = _episodeSearchDebounceCts.Token;

        try
        {
            await Task.Delay(SearchDebounceMs, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        await GetEpisodes(_currentEpisodePage, token);
        _isLoadingEpisodes = false;
        StateHasChanged();
    }

    private async Task OnEpisodePageChanged(int page)
    {
        _currentEpisodePage = page;
        using CancellationTokenSource cts = new();
        await GetEpisodes(page, cts.Token);
        StateHasChanged();
    }

    private async Task GetTopic(CancellationToken cancellationToken)
    {
        var topicResult = await ClientService.GetTopicById(Id, cancellationToken);

        await HandleResult(
            topicResult,
            topic =>
            {
                _topic = topic;
                BreadcrumbService.ReplaceLast(topic.Name);
                return Task.CompletedTask;
            },
            () =>
            {
                // TODO Figure out how to handle no content (e.g., show a "not found" message)
                Logger.LogWarning("No topic found with ID {Id}.", Id);
                return Task.CompletedTask;
            });
    }

    private async Task GetTopicDetails(CancellationToken cancellationToken)
    {
        var topicDetailsResult = await ClientService.GetTopicDetailsById(Id, cancellationToken);

        await HandleResult(
            topicDetailsResult,
            topicDetails =>
            {
                _topicDetails = topicDetails;
                return Task.CompletedTask;
            },
            () =>
            {
                // TODO Figure out how to handle no content (e.g., show a "not found" message)
                Logger.LogWarning("No topic details found for topic ID {Id}.", Id);
                return Task.CompletedTask;
            });
    }

    private async Task GetEpisodes(int pageNumber, CancellationToken cancellationToken)
    {
        string? searchTerm = string.IsNullOrWhiteSpace(_episodeSearchTerm) ? null : _episodeSearchTerm;
        PagedItemRequest pagedRequest = new(pageNumber, PageSize, searchTerm);
        var episodesResult = await ClientService.GetEpisodesByTopicId(Id, pagedRequest, cancellationToken);

        await HandleResult(
            episodesResult,
            episodesResponse =>
            {
                _episodesResponse = episodesResponse;
                return Task.CompletedTask;
            },
            () =>
            {
                _episodesResponse = new PagedResponse<Episode>([], 0, pageNumber, PageSize);
                return Task.CompletedTask;
            });
    }

    private async Task GetPersons(CancellationToken cancellationToken)
    {
        var personsResult = await ClientService.GetPersonsByTopicId(Id, cancellationToken);

        await HandleResult(
            personsResult,
            persons =>
            {
                _persons = persons;
                return Task.CompletedTask;
            },
            () =>
            {
                // TODO Figure out how to handle no content (e.g., show a "not found" message)
                Logger.LogWarning("No persons found for topic ID {Id}.", Id);
                return Task.CompletedTask;
            });
    }

    public void Dispose()
    {
        _episodeSearchDebounceCts?.Cancel();
        _episodeSearchDebounceCts?.Dispose();
    }
}
