@page "/Topic/{Id:int}"

@using TheLsmArchive.ApiClient.Services.Abstractions
@using TheLsmArchive.Models.Request
@using TheLsmArchive.Web.Frontend.Pages.Abstractions

@inherits BasePage

@implements IDisposable

@inject ILogger<TopicPage> Logger
@inject ILsmArchiveClientService ClientService
@inject NavigationManager NavigationManager
@inject IBreadcrumbService BreadcrumbService

<MudGrid Spacing="5">
    @if (_topic != null && _timeline != null)
    {
        <MudItem xs="12">
            <MudStack Class="page-hero-header hero-tertiary">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                    <MudAvatar Color="Color.Tertiary" Variant="Variant.Outlined" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Medium"/>
                    </MudAvatar>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h4" Class="fw-bold">@_topic.Name</MudText>
                        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="flex-wrap">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Tertiary"/>
                                <MudText Typo="Typo.body2" Style="opacity: 0.8;">
                                    First Discussed <strong>@_timeline.FirstDiscussed.ToShortDateString()</strong>
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Color="Color.Tertiary"/>
                                <MudText Typo="Typo.body2" Style="opacity: 0.8;">
                                    Last Discussed <strong>@_timeline.LastDiscussed.ToShortDateString()</strong>
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudStack>
            <MudDivider Class="mt-4 mb-2"/>
        </MudItem>

        @if (_mostDiscussedAlongside is { Count: > 0 })
        {
            <MudItem xs="12">
                <SectionHeader Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Tertiary" Title="Most Discussed Alongside"/>
                <MudGrid Spacing="2" Class="mt-2">
                    @for (int index = 0; index < _mostDiscussedAlongside.Count; index++)
                    {
                        var topic = _mostDiscussedAlongside[index];
                        var rank = index + 1;

                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4 h-100 entity-card card-hover hover-tertiary clickable-card" Elevation="1"
                                      @onclick='@(() => NavigationManager.NavigateTo($"/Topic/{topic.Id}"))'>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudChip T="string"
                                                 Color="Color.Tertiary"
                                                 Variant="Variant.Outlined"
                                                 Size="Size.Small">
                                            #@rank
                                        </MudChip>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Tag" Color="Color.Tertiary" Size="Size.Small" />
                                            <MudText Typo="Typo.body1" Class="fw-bold">@topic.Name</MudText>
                                        </MudStack>
                                    </MudStack>
                                    <MudChip T="string"
                                             Color="Color.Tertiary"
                                             Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.Forum">
                                        @(topic.EpisodeCount == 1 ? "1 episode" : $"{topic.EpisodeCount} episodes")
                                    </MudChip>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
                <MudDivider Class="mt-4 mb-2"/>
            </MudItem>
        }

        @if (_timeline != null)
        {
            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <SectionHeader Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Title="Timeline"/>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudTextField T="string"
                                      Variant="Variant.Outlined"
                                      Placeholder="Search episodes..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      AdornmentColor="Color.Primary"
                                      Value="_searchTerm"
                                      ValueChanged="OnSearchTermChanged"
                                      Immediate="true"
                                      Clearable="true"
                                      Margin="Margin.Dense"
                                      Style="max-width: 300px;"/>
                        <MudTooltip Text="@(_sortDescending ? "Showing newest first" : "Showing oldest first")">
                            <MudIconButton Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                           Color="Color.Primary"
                                           OnClick="ToggleSort"/>
                        </MudTooltip>
                    </MudStack>
                </MudStack>
                @if (_timeline.Entries.Items.Count > 0)
                {
                    <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                        @foreach (var entry in _timeline.Entries.Items)
                        {
                            <MudTimelineItem Color="Color.Primary" Size="Size.Small" Icon="@Icons.Material.Filled.Headphones">
                                <ChildContent>
                                    <MudCard Class="card-hover hover-primary entity-card clickable-card" Elevation="2">
                                        <MudCardContent @onclick='() => NavigationManager.NavigateTo($"/Episode/{entry.EpisodeId}")'>
                                            <MudText Typo="Typo.body1" Class="fw-bold">@entry.Title</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Primary" Class="mb-2">@entry.ReleaseDate.ToLongDateString()</MudText>
                                            @if (entry.People.Count > 0)
                                            {
                                                <MudStack Row="true" Class="flex-wrap" Spacing="1">
                                                    @foreach (var person in entry.People)
                                                    {
                                                        <MudChip T="string"
                                                                 Icon="@Icons.Material.Filled.Person"
                                                                 Color="Color.Secondary"
                                                                 Variant="Variant.Text"
                                                                 Size="Size.Small"
                                                                 OnClick="@(() => NavigationManager.NavigateTo($"/Person/{person.Id}"))">
                                                            @person.Name
                                                        </MudChip>
                                                    }
                                                </MudStack>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </ChildContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                    @if (_timeline.Entries.TotalPages > 1)
                    {
                        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                            <MudPagination Count="@_timeline.Entries.TotalPages"
                                           Selected="@_currentPage"
                                           SelectedChanged="OnPageChanged"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           BoundaryCount="1"
                                           MiddleCount="3"
                                           ShowFirstButton="true"
                                           ShowLastButton="true"/>
                        </MudStack>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body1" Color="Color.Default" Class="mt-4">No episodes found.</MudText>
                }
            </MudItem>
        }
    }
    else
    {
        <MudItem xs="12">
            <MudStack Class="pl-6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px"/>
                    <MudStack Spacing="1">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="240px" Height="40px"/>
                        <MudStack Row="true" Spacing="4">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="18px"/>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="18px"/>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudStack>
            <MudDivider Class="mt-4 mb-2"/>
        </MudItem>
    }
</MudGrid>

@code {
    private const int PageSize = 25;
    private const int SearchDebounceMs = 350;

    [Parameter]
    public int Id { get; set; }

    private Topic? _topic;

    private TopicTimeline? _timeline;

    private List<MostDiscussedTopic>? _mostDiscussedAlongside;

    private int _currentPage = 1;

    private string _searchTerm = string.Empty;

    private bool _sortDescending = true;

    private CancellationTokenSource? _searchDebounceCts;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        BreadcrumbService.Push("Loading...", NavigationManager.Uri, Icons.Material.Filled.Tag);

        using CancellationTokenSource cts = new();

        var getTopicTask = GetTopic(cts.Token);
        var getTimelineTask = GetTimeline(_currentPage, cts.Token);
        var getMostDiscussedAlongsideTask = GetMostDiscussedAlongside(cts.Token);

        await Task.WhenAll(getTopicTask, getTimelineTask, getMostDiscussedAlongsideTask);
    }

    private async Task GetTopic(CancellationToken cancellationToken)
    {
        var topicResult = await ClientService.GetTopicById(Id, cancellationToken);

        await HandleResult(
            topicResult,
            topic =>
            {
                _topic = topic;
                BreadcrumbService.ReplaceLast(topic.Name);
                return Task.CompletedTask;
            },
            () =>
            {
                Logger.LogWarning("No topic found with ID {Id}.", Id);
                return Task.CompletedTask;
            });
    }

    private async Task GetTimeline(int pageNumber, CancellationToken cancellationToken)
    {
        string? searchTerm = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm;
        PagedItemRequest pagedRequest = new(pageNumber, PageSize, searchTerm);
        var timelineResult = await ClientService.GetTopicTimelineById(Id, pagedRequest, _sortDescending, cancellationToken);

        await HandleResult(
            timelineResult,
            timeline =>
            {
                _timeline = timeline;
                return Task.CompletedTask;
            },
            () =>
            {
                Logger.LogWarning("No timeline found for topic ID {Id}.", Id);
                return Task.CompletedTask;
            });
    }

    private async Task GetMostDiscussedAlongside(CancellationToken cancellationToken)
    {
        var result = await ClientService.GetMostDiscussedAlongsideTopicsByTopicId(Id, cancellationToken);

        await HandleResult(
            result,
            topics =>
            {
                _mostDiscussedAlongside = topics;
                return Task.CompletedTask;
            },
            () =>
            {
                _mostDiscussedAlongside = [];
                return Task.CompletedTask;
            });
    }

    private async Task OnSearchTermChanged(string value)
    {
        _searchTerm = value;
        _currentPage = 1;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts = new CancellationTokenSource();
        var token = _searchDebounceCts.Token;

        try
        {
            await Task.Delay(SearchDebounceMs, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        await GetTimeline(_currentPage, token);
        StateHasChanged();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        using CancellationTokenSource cts = new();
        await GetTimeline(page, cts.Token);
        StateHasChanged();
    }

    private async Task ToggleSort()
    {
        _sortDescending = !_sortDescending;
        _currentPage = 1;
        using CancellationTokenSource cts = new();
        await GetTimeline(_currentPage, cts.Token);
        StateHasChanged();
    }

    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
    }
}
