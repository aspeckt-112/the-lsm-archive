{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "TheLsmArchive.Patreon.Ingestion"
    }
  },
  "RssFeedSources": [],
  "UserAgentOptions": {
    "UserAgent": "TheLsmArchive.PatreonFeed.Reader",
    "Version": "1.0.0"
  },
  "PatreonIngestionOptions": {
    "RefreshIntervalInMinutes": 60
  },
  "GeminiOptions": {
    "ApiKey": "",
    "Model": "gemini-3-flash-preview",
    "TimeoutInMilliseconds": 3600000 // 1 hour
  },
  "ConnectionStrings": {
    "thelsmarchive": ""
  }
}
