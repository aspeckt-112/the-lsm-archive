{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": {
      "ConsoleSink": {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      "FileSink": {
        "Name": "File",
        "Args": {
          "path": "logs/patreon-ingestion-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    },
    "Properties": {
      "Application": "TheLsmArchive.Patreon.Ingestion"
    }
  },
  "RssFeedSources": [],
  "UserAgentOptions": {
    "UserAgent": "TheLsmArchive.PatreonFeed.Reader",
    "Version": "1.0.0"
  },
  "PatreonIngestionOptions": {
    "RefreshIntervalInMinutes": 60
  },
  "GeminiOptions": {
    "ApiKey": "",
    "Model": "gemini-3-flash-preview"
  },
  "ConnectionStrings": {
    "thelsmarchive": ""
  }
}
